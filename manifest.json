{
  "manifest_version": 3,
  "name": "Desmos CAS",
  "version": "2.0",
  "description": "Adds symbolic CAS capabilities to Desmos via SymPy",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["offscreen"],
  "content_scripts": [
    {
      "matches": ["*://*.desmos.com/*"],
      "js": ["loader.js", "bridge.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["cas.js"],
      "matches": ["*://*.desmos.com/*"]
    }
  ]
}
